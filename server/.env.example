# Server environment variables (override config.toml defaults)
# All values are optional; config.toml is the primary configuration source.

# Server
WHISDOM_SERVER_PORT=8788
WHISDOM_THREADS=0

# Auth
WHISDOM_ALLOWED_ORIGIN=http://localhost:5173
WHISDOM_ALLOWED_EMAILS=
WHISDOM_ALLOWED_DOMAINS=

# Paths
WHISDOM_MODEL_DIR=./models
WHISDOM_MODEL_DEFAULT=base

# GPU (requires a GPU-enabled build via `cargo build --features cuda|vulkan|hipblas`)
WHISDOM_GPU_ENABLED=false
WHISDOM_GPU_DEVICE=0

WHISDOM_TEMP_DIR=./tmp
WHISDOM_YTDLP_PATH=yt-dlp
WHISDOM_FFMPEG_PATH=ffmpeg

# Limits
WHISDOM_MAX_UPLOAD_MB=500

# Turnstile (set both to enable)
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
